<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <DesignationCategoryDef>
    <defName>PipedCEAutoloaders_PipeNetworks</defName>
    <label>ammunition pipes</label>
    <order>351</order>
    <specialDesignatorClasses>
      <li>Designator_Cancel</li>
      <li>Designator_Deconstruct</li>
    </specialDesignatorClasses>
  </DesignationCategoryDef>

  <PipeSystem.PipeNetDef>
    <defName>PipedCEAutoloaders_AmberNet</defName>
    <resource>
      <name>amber ammunition rounds</name>
      <unit>rounds</unit>
      <color>(0.78,0.62,0.22)</color>
      <onlyShowStored>true</onlyShowStored>
      <offTexPath>Things/Ammo/Rifle/Battlerifle/FMJ/FMJ_c</offTexPath>
    </resource>
    <pipeDefs><li>PipedCEAutoloaders_AmberPipe</li></pipeDefs>
    <designator><deconstructIconPath>UI/Designators/Deconstruct</deconstructIconPath><designationCategoryDef>PipedCEAutoloaders_PipeNetworks</designationCategoryDef></designator>
    <overlayOptions><overlayColor>(0.78,0.62,0.22)</overlayColor></overlayOptions>
  </PipeSystem.PipeNetDef>

  <PipeSystem.PipeNetDef>
    <defName>PipedCEAutoloaders_BlueNet</defName>
    <resource>
      <name>blue ammunition rounds</name>
      <unit>rounds</unit>
      <color>(0.25,0.55,0.9)</color>
      <onlyShowStored>true</onlyShowStored>
      <offTexPath>Things/Ammo/Rifle/Battlerifle/FMJ/FMJ_c</offTexPath>
    </resource>
    <pipeDefs><li>PipedCEAutoloaders_BluePipe</li></pipeDefs>
    <designator><deconstructIconPath>UI/Designators/Deconstruct</deconstructIconPath><designationCategoryDef>PipedCEAutoloaders_PipeNetworks</designationCategoryDef></designator>
    <overlayOptions><overlayColor>(0.25,0.55,0.9)</overlayColor></overlayOptions>
  </PipeSystem.PipeNetDef>

  <PipeSystem.PipeNetDef>
    <defName>PipedCEAutoloaders_GreenNet</defName>
    <resource>
      <name>green ammunition rounds</name>
      <unit>rounds</unit>
      <color>(0.35,0.75,0.4)</color>
      <onlyShowStored>true</onlyShowStored>
      <offTexPath>Things/Ammo/Shotgun/Shot</offTexPath>
    </resource>
    <pipeDefs><li>PipedCEAutoloaders_GreenPipe</li></pipeDefs>
    <designator><deconstructIconPath>UI/Designators/Deconstruct</deconstructIconPath><designationCategoryDef>PipedCEAutoloaders_PipeNetworks</designationCategoryDef></designator>
    <overlayOptions><overlayColor>(0.35,0.75,0.4)</overlayColor></overlayOptions>
  </PipeSystem.PipeNetDef>

  <ThingDef ParentName="BuildingBase" Name="PipedCEAutoloaders_PipeBase" Abstract="True">
    <thingClass>PipeSystem.Building_Pipe</thingClass>
    <category>Building</category>
    <tickerType>Rare</tickerType>
    <graphicData>
      <texPath>Things/Building/Linked/PowerConduit_Atlas</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <linkType>Basic</linkType>
      <linkFlags><li>Custom7</li></linkFlags>
    </graphicData>
    <uiIconPath>Things/Building/Linked/PowerConduit_MenuIcon</uiIconPath>
    <building><isInert>true</isInert><isEdifice>false</isEdifice><blueprintGraphicData><texPath>Things/Building/Linked/PowerConduit_Blueprint_Atlas</texPath></blueprintGraphicData><canConstructInCorner>true</canConstructInCorner></building>
    <drawerType>MapMeshOnly</drawerType>
    <altitudeLayer>Conduits</altitudeLayer>
    <passability>Standable</passability>
    <statBases><MaxHitPoints>40</MaxHitPoints><WorkToBuild>35</WorkToBuild><Flammability>1</Flammability></statBases>
    <costList><Steel>2</Steel></costList>
    <placeWorkers><li>PipeSystem.PlaceWorker_Pipe</li></placeWorkers>
    <rotatable>false</rotatable>
    <neverMultiSelect>true</neverMultiSelect>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>PipedCEAutoloaders_PipeNetworks</designationCategory>
    <constructEffect>ConstructMetal</constructEffect>
    <clearBuildingArea>false</clearBuildingArea>
    <researchPrerequisites><li>GunTurrets</li></researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="PipedCEAutoloaders_PipeBase">
    <defName>PipedCEAutoloaders_AmberPipe</defName><label>amber ammunition pipe</label><description>Transfers rounds assigned to the amber ammunition network.</description>
    <comps><li Class="PipeSystem.CompProperties_Resource"><pipeNet>PipedCEAutoloaders_AmberNet</pipeNet></li></comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_PipeBase">
    <defName>PipedCEAutoloaders_BluePipe</defName><label>blue ammunition pipe</label><description>Transfers rounds assigned to the blue ammunition network.</description>
    <comps><li Class="PipeSystem.CompProperties_Resource"><pipeNet>PipedCEAutoloaders_BlueNet</pipeNet></li></comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_PipeBase">
    <defName>PipedCEAutoloaders_GreenPipe</defName><label>green ammunition pipe</label><description>Transfers rounds assigned to the green ammunition network.</description>
    <comps><li Class="PipeSystem.CompProperties_Resource"><pipeNet>PipedCEAutoloaders_GreenNet</pipeNet></li></comps>
  </ThingDef>

  <ThingDef ParentName="BuildingBase" Name="PipedCEAutoloaders_TankBase" Abstract="True">
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData><texPath>Things/Building/Power/Battery</texPath><graphicClass>Graphic_Multi</graphicClass><drawSize>(2,2)</drawSize></graphicData>
    <altitudeLayer>Building</altitudeLayer><passability>Impassable</passability><fillPercent>1</fillPercent><tickerType>Normal</tickerType><size>(2,2)</size>
    <statBases><MaxHitPoints>150</MaxHitPoints><WorkToBuild>800</WorkToBuild><Mass>20</Mass><Flammability>0.5</Flammability></statBases>
    <costList><Steel>100</Steel><ComponentIndustrial>2</ComponentIndustrial></costList>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded><designationCategory>PipedCEAutoloaders_PipeNetworks</designationCategory><constructEffect>ConstructMetal</constructEffect>
    <researchPrerequisites><li>GunTurrets</li></researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="PipedCEAutoloaders_TankBase">
    <defName>PipedCEAutoloaders_AmberTank</defName><label>amber ammunition tank</label><description>Stores rounds assigned to the amber ammunition network.</description>
    <comps><li Class="PipeSystem.CompProperties_ResourceStorage"><pipeNet>PipedCEAutoloaders_AmberNet</pipeNet><storageCapacity>1000</storageCapacity><barSize>(1.3,0.25)</barSize><centerOffset>(0,0,0.35)</centerOffset></li></comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_TankBase">
    <defName>PipedCEAutoloaders_BlueTank</defName><label>blue ammunition tank</label><description>Stores rounds assigned to the blue ammunition network.</description>
    <comps><li Class="PipeSystem.CompProperties_ResourceStorage"><pipeNet>PipedCEAutoloaders_BlueNet</pipeNet><storageCapacity>1000</storageCapacity><barSize>(1.3,0.25)</barSize><centerOffset>(0,0,0.35)</centerOffset></li></comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_TankBase">
    <defName>PipedCEAutoloaders_GreenTank</defName><label>green ammunition tank</label><description>Stores rounds assigned to the green ammunition network.</description>
    <comps><li Class="PipeSystem.CompProperties_ResourceStorage"><pipeNet>PipedCEAutoloaders_GreenNet</pipeNet><storageCapacity>1000</storageCapacity><barSize>(1.3,0.25)</barSize><centerOffset>(0,0,0.35)</centerOffset></li></comps>
  </ThingDef>

  <ThingDef ParentName="FurnitureBase" Name="PipedCEAutoloaders_InputBase" Abstract="True">
    <thingClass>Building_Storage</thingClass>
    <tickerType>Normal</tickerType>
    <graphicData><texPath>Things/Ammo/Rifle/Battlerifle/FMJ/FMJ_c</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>(1,1)</drawSize><drawRotated>false</drawRotated><allowFlip>false</allowFlip></graphicData>
    <rotatable>false</rotatable><altitudeLayer>BuildingOnTop</altitudeLayer><passability>Standable</passability><fillPercent>0.5</fillPercent><pathCost>50</pathCost><size>(1,1)</size>
    <statBases><MaxHitPoints>100</MaxHitPoints><WorkToBuild>500</WorkToBuild><Mass>8</Mass><Flammability>0.5</Flammability></statBases>
    <costList><Steel>45</Steel><ComponentIndustrial>1</ComponentIndustrial></costList>
    <building>
      <blueprintClass>Blueprint_Storage</blueprintClass><preventDeteriorationOnTop>true</preventDeteriorationOnTop><ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
      <fixedStorageSettings><filter><disallowNotEverStorable>true</disallowNotEverStorable><thingDefs><li>Ammo_762x51mmNATO_FMJ</li></thingDefs></filter></fixedStorageSettings>
      <defaultStorageSettings><priority>Important</priority><filter><disallowNotEverStorable>true</disallowNotEverStorable><thingDefs><li>Ammo_762x51mmNATO_FMJ</li></thingDefs></filter></defaultStorageSettings>
    </building>
    <inspectorTabs><li>ITab_Storage</li></inspectorTabs><surfaceType>Item</surfaceType><canOverlapZones>false</canOverlapZones>
    <designationCategory>PipedCEAutoloaders_PipeNetworks</designationCategory><researchPrerequisites><li>GunTurrets</li></researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="PipedCEAutoloaders_InputBase">
    <defName>PipedCEAutoloaders_AmberInput</defName><label>amber ammunition input</label><description>Consumes the exact physical round assigned to the amber network. One item contributes its Combat Extended round count.</description>
    <comps><li Class="PipedCEAutoloaders.CompProperties_PipedAmmoInput"><pipeNet>PipedCEAutoloaders_AmberNet</pipeNet></li></comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_InputBase">
    <defName>PipedCEAutoloaders_BlueInput</defName><label>blue ammunition input</label><description>Consumes the exact physical round assigned to the blue network. One item contributes its Combat Extended round count.</description>
    <comps><li Class="PipedCEAutoloaders.CompProperties_PipedAmmoInput"><pipeNet>PipedCEAutoloaders_BlueNet</pipeNet></li></comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_InputBase">
    <defName>PipedCEAutoloaders_GreenInput</defName><label>green ammunition input</label><description>Consumes the exact physical round assigned to the green network. One item contributes its Combat Extended round count.</description>
    <comps><li Class="PipedCEAutoloaders.CompProperties_PipedAmmoInput"><pipeNet>PipedCEAutoloaders_GreenNet</pipeNet></li></comps>
  </ThingDef>
