<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--
    The shared loader is a powered CE autoloader with a VEF supply component.
    Normal ticking is required for pipe withdrawal and reload cancellation;
    CompAmmoUser remains the durable buffer used by CE's native turret path.
  -->
  <ThingDef ParentName="BuildingBase" Name="PipedCEAutoloaders_AutoloaderBase" Abstract="True">
    <thingClass>PipedCEAutoloaders.Building_PipeBackedAutoloaderCE</thingClass>
    <tickerType>Normal</tickerType><drawerType>MapMeshAndRealTime</drawerType>
    <graphicData><texPath>Things/Ammo/Rifle/Battlerifle/FMJ/FMJ_c</texPath><graphicClass>Graphic_Single</graphicClass><drawSize>(1,1)</drawSize><drawRotated>false</drawRotated><allowFlip>false</allowFlip></graphicData>
    <rotatable>false</rotatable><altitudeLayer>Building</altitudeLayer><passability>PassThroughOnly</passability><castEdgeShadows>true</castEdgeShadows><hasInteractionCell>false</hasInteractionCell><fillPercent>0.5</fillPercent><size>(1,1)</size>
    <costList><Steel>120</Steel><ComponentIndustrial>2</ComponentIndustrial></costList>
    <building><destroySound>BuildingDestroyed_Metal_Small</destroySound></building>
    <statBases><MaxHitPoints>100</MaxHitPoints><WorkToBuild>1200</WorkToBuild><Mass>20</Mass><Flammability>0.5</Flammability><ReloadSpeed>0.5</ReloadSpeed></statBases>
    <researchPrerequisites><li>GunTurrets</li></researchPrerequisites><designationCategory>PipedCEAutoloaders_PipeNetworks</designationCategory><minifiedDef>MinifiedThing</minifiedDef><thingCategories><li>BuildingsSecurity</li></thingCategories>
    <comps>
      <li Class="CompProperties_Power"><compClass>CompPowerTrader</compClass><basePowerConsumption>100</basePowerConsumption></li>
    </comps>
  </ThingDef>

  <!--
    Concrete loaders pair one network with a valid startup AmmoSetDef. Settings
    replace that ammo set and inherited reload speed before spawned instances
    use them, while magazine size and CE base timing remain shared contracts.
  -->
  <ThingDef ParentName="PipedCEAutoloaders_AutoloaderBase">
    <defName>PipedCEAutoloaders_AmberAutoloader</defName><label>amber piped autoloader</label><description>Automatically reloads a compatible adjacent Combat Extended turret using ammunition from the amber network. Requires power.</description>
    <graphicData><texPath>Things/Building/PipedCEAutoloaders/AmberAutoloader</texPath></graphicData>
    <comps>
      <li Class="CombatExtended.CompProperties_AmmoListUser"><magazineSize>400</magazineSize><reloadTime>7.8</reloadTime><ammoSet>AmmoSet_762x51mmNATO</ammoSet></li>
      <li Class="PipeSystem.CompProperties_Resource"><pipeNet>PipedCEAutoloaders_AmberNet</pipeNet></li>
    </comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_AutoloaderBase">
    <defName>PipedCEAutoloaders_BlueAutoloader</defName><label>blue piped autoloader</label><description>Automatically reloads a compatible adjacent Combat Extended turret using ammunition from the blue network. Requires power.</description>
    <graphicData><texPath>Things/Building/PipedCEAutoloaders/BlueAutoloader</texPath></graphicData>
    <comps>
      <li Class="CombatExtended.CompProperties_AmmoListUser"><magazineSize>400</magazineSize><reloadTime>7.8</reloadTime><ammoSet>AmmoSet_556x45mmNATO</ammoSet></li>
      <li Class="PipeSystem.CompProperties_Resource"><pipeNet>PipedCEAutoloaders_BlueNet</pipeNet></li>
    </comps>
  </ThingDef>
  <ThingDef ParentName="PipedCEAutoloaders_AutoloaderBase">
    <defName>PipedCEAutoloaders_GreenAutoloader</defName><label>green piped autoloader</label><description>Automatically reloads a compatible adjacent Combat Extended turret using ammunition from the green network. Requires power.</description>
    <graphicData><texPath>Things/Building/PipedCEAutoloaders/GreenAutoloader</texPath></graphicData>
    <comps>
      <li Class="CombatExtended.CompProperties_AmmoListUser"><magazineSize>400</magazineSize><reloadTime>7.8</reloadTime><ammoSet>AmmoSet_12Gauge</ammoSet></li>
      <li Class="PipeSystem.CompProperties_Resource"><pipeNet>PipedCEAutoloaders_GreenNet</pipeNet></li>
    </comps>
  </ThingDef>
</Defs>
